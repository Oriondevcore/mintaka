REM ════════════════════════════════════════════════════════════════════════════════
REM ORION MINTAKA - SETUP.BAT ECHO COMMANDS
REM ════════════════════════════════════════════════════════════════════════════════
REM
REM INSTRUCTIONS:
REM 1. Open Command Prompt (cmd.exe) as Administrator
REM 2. Navigate to C:\MINTAKA
REM 3. Copy ALL the lines below (between === markers)
REM 4. Paste into Command Prompt and press Enter
REM 5. setup.bat will be created
REM
REM ════════════════════════════════════════════════════════════════════════════════
REM START: Copy everything from here to END marker

(
echo @echo off
echo REM ORION MINTAKA - PRODUCTION SETUP SCRIPT
echo REM Version: 1.0
echo REM Last Updated: 17 March 2026
echo REM
echo setlocal enabledelayedexpansion
echo
echo title ORION MINTAKA - SETUP
echo cls
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║                                                                ║
echo ║   🌟 ORION MINTAKA - PRODUCTION SETUP                         ║
echo ║   Built in Africa. Engineered for Impact.                     ║
echo ║                                                                ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo [1] Checking prerequisites...
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [1.1] Checking for Bun...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bun --version ^>nul 2^>^&1
if errorlevel 1 (
    echo ❌ Bun not found
    echo Please install from: https://bun.sh
    pause
    exit /b 1
)
echo ✅ Bun installed
bun --version
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [1.2] Checking for Node.js...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
node --version ^>nul 2^>^&1
if errorlevel 1 (
    echo ❌ Node.js not found
    echo Please install from: https://nodejs.org
    pause
    exit /b 1
)
echo ✅ Node.js installed
node --version
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [1.3] Checking for PM2...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
pm2 --version ^>nul 2^>^&1
if errorlevel 1 (
    echo ⚠️  PM2 not found - installing globally...
    npm install -g pm2
) else (
    echo ✅ PM2 installed
    pm2 --version
)
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [2] Creating folder structure...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
mkdir outputs
mkdir outputs\proposals
mkdir outputs\documents
mkdir outputs\code
mkdir outputs\data
mkdir outputs\archive
mkdir documents
mkdir knowledge
mkdir data
mkdir logs
mkdir temp
echo ✅ Folders created
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [3] Installing dependencies...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bun install
if errorlevel 1 (
    echo ❌ Installation failed
    pause
    exit /b 1
)
echo ✅ Dependencies installed
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [4] Checking for .env file...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if not exist .env (
    echo ⚠️  .env file not found
    echo.
    echo Creating from template...
    copy .env.example .env 2^>nul
    if errorlevel 1 (
        echo ❌ Could not create .env
        echo Please create manually:
        echo - Copy: .env.example to .env
        echo - Edit: .env with your API keys
        pause
        exit /b 1
    )
    echo ✅ .env created from template
    echo.
    echo ⚠️  IMPORTANT: Edit .env with your API keys!
    echo - GROQ_API_KEY
    echo - OPENROUTER_KEY
    echo - GEMINI_API_KEY
    echo - SMTP credentials
    echo.
) else (
    echo ✅ .env already exists
)
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [5] Verifying code files...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set /a missing=0
for %%F in (index.js ai.js files.js email.js stt.js vision.js memory.js prompt.js package.json ecosystem.config.js) do (
    if exist %%F (
        echo ✅ %%F
    ) else (
        echo ❌ %%F - MISSING
        set /a missing=!missing! + 1
    )
)
if !missing! gtr 0 (
    echo.
    echo ❌ !missing! file(s) missing
    echo Please copy all production files to C:\MINTAKA\
    pause
    exit /b 1
)
echo.
echo ✅ All code files present
echo.
echo.
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
echo [6] Setting up PM2...
echo ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
pm2 delete mintaka 2^>nul
pm2 start ecosystem.config.js
pm2 save
echo ✅ PM2 configured
echo.
echo.
echo ╔════════════════════════════════════════════════════════════════╗
echo ║                                                                ║
echo ║   ✅ SETUP COMPLETE!                                          ║
echo ║                                                                ║
echo ╚════════════════════════════════════════════════════════════════╝
echo.
echo NEXT STEPS:
echo.
echo 1. Edit your .env file with API keys:
echo    notepad .env
echo.
echo 2. Check Mintaka status:
echo    pm2 status
echo.
echo 3. View logs:
echo    pm2 logs mintaka
echo.
echo 4. Scan WhatsApp QR code when you see it
echo.
echo 5. Send a message to test
echo.
echo DOCUMENTATION:
echo - README.md          - How to run
echo - ARCHITECTURE.md    - System design
echo - COMMANDS.md        - Bun/PM2/ngrok commands
echo - TROUBLESHOOTING.md - Debug guide
echo - guardrails.md      - Permissions
echo - DEVLOG.md          - Build status
echo.
echo CONTACT:
echo - Graham: graham@oriondevcore.com
echo - Mintaka: mintaka@mintaka.oriondevcore.com
echo.
echo Built in Africa. Engineered for Impact. 🌍
echo.
pause
) > setup.bat

echo.
echo ✅ setup.bat created successfully!
echo.
echo Next steps:
echo 1. Edit .env with your API keys
echo 2. Run: pm2 start ecosystem.config.js
echo 3. Scan WhatsApp QR code
echo 4. Test by sending a message
echo.
